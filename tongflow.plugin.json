{
    "plugin": {
        "name": "FLUX.2 Klein",
        "description": "Multi-reference image fusion and instruction-based editing with FLUX.2 Klein 9B (Black Forest Labs).",
        "icon": "/plugins/tongflow-modal-flux2-klein9b.svg"
    },
    "env": [
        {
            "key": "MODAL_TOKEN_ID",
            "required": true,
            "description": "Modal token id",
            "url": "https://modal.com/settings/tokens"
        },
        {
            "key": "MODAL_TOKEN_SECRET",
            "required": true,
            "description": "Modal token secret (paired with MODAL_TOKEN_ID)"
        },
        {
            "key": "HF_TOKEN",
            "description": "FLUX.2 is gated — accept the FLUX license on Hugging Face first",
            "url": "https://huggingface.co/settings/tokens",
            "required": true
        },
        {
            "key": "TONGFLOW_MODAL_CALL_TIMEOUT_S",
            "default": "2400",
            "description": "Max seconds to wait for a Modal call"
        }
    ]
}
